default_platform(:ios)

platform :ios do
  desc "Build PassCheck and upload to TestFlight (uses App Store Connect API key)"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"] || "asc_key.p8"
    )

    # Create the app record in App Store Connect if it doesn't exist yet.
    # (app_name must be unique on the App Store — adjust if taken.)
    begin
      produce(
        app_identifier: "com.appstudio.passcheck",
        app_name: "PassCheck Photo Checker",
        language: "English",
        sku: "passcheck-0001",
        api_key: api_key
      )
    rescue => e
      UI.important("produce skipped/failed (app may already exist): #{e}")
    end

    build_app(
      project: "PassCheck.xcodeproj",
      scheme: "PassCheck",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: "645SRC2PTY"
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
