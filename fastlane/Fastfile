default_platform(:ios)

APP_ID  = "com.appstudio.passcheck"
TEAM_ID = "645SRC2PTY"

platform :ios do
  desc "Build PassCheck and upload to TestFlight (App Store Connect API key, manual signing)"
  lane :beta do
    # CI machines have no login keychain / Apple account. This creates a temporary
    # keychain so the signing certificate can be imported.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"] || "asc_key.p8"
    )

    # NOTE: `produce` cannot create the App Store Connect app record with an API key
    # (Apple requires an Apple ID login for that). The record is created once by hand
    # in App Store Connect; see TESTFLIGHT_SETUP.md.

    # Certificates must land in the temporary CI keychain, not the (locked) login keychain.
    keychain_name = ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain"
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    keychain_pw   = ENV["MATCH_KEYCHAIN_PASSWORD"] || ""

    cert_opts = {
      api_key: api_key,
      team_id: TEAM_ID,
      keychain_path: keychain_path,
      keychain_password: keychain_pw
    }

    begin
      cert(cert_opts)
    rescue => e
      # Only ever triggered by Apple's "maximum number of certificates" response.
      #
      # CI runners are destroyed after every run, so the private key of a certificate
      # created here is gone the moment the job ends and the certificate can never sign
      # anything again. The owner has no Mac, so no local key exists either — these are
      # dead entries occupying a hard limit of two.
      #
      # Owner approved this cleanup explicitly on 2026-07-20 and again on 2026-07-21.
      # It is a stopgap: the permanent fix is a single stable certificate stored as a
      # secret and imported each run, which removes this branch entirely. See D-015.
      raise e unless e.message.to_s.include?("maximum number")

      UI.important("Distribution certificate limit reached — clearing unusable certificates.")
      revoked = []
      Spaceship::ConnectAPI::Certificate.all.each do |c|
        next unless c.certificate_type.to_s.upcase.include?("DISTRIBUTION")
        UI.important("Revoking #{c.id} (#{c.display_name}, #{c.certificate_type})")
        c.delete!
        revoked << c.id
      end
      UI.user_error!("Hit the certificate limit but found none to clear.") if revoked.empty?
      UI.success("Cleared #{revoked.count}: #{revoked.join(', ')} — creating a fresh certificate.")
      cert(cert_opts)
    end
    # sigh needs the bundle identifier to already exist on the developer portal.
    if Spaceship::ConnectAPI::BundleId.find(APP_ID).nil?
      UI.user_error!("Bundle identifier #{APP_ID} does not exist. Register it explicitly in Apple Developer before retrying; CI will not create it automatically.")
    end

    sigh(api_key: api_key, app_identifier: APP_ID, team_id: TEAM_ID)

    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.message("Using provisioning profile: #{profile_name}")

    # Automatic signing cannot work without a logged-in Xcode account — switch to manual.
    update_code_signing_settings(
      path: "PassCheck.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      targets: ["PassCheck"],
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name
    )

    # Apple rejects a build number it has already seen. Deriving it from the CI run
    # number makes it strictly increasing. Passed as a build setting rather than edited
    # into project.yml, because in-place `sed` is not portable across runner images and
    # failed silently there — the upload was rejected for reusing build "1".
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%y%m%d%H%M")
    UI.message("Building as version #{build_number}")

    build_app(
      project: "PassCheck.xcodeproj",
      scheme: "PassCheck",
      export_method: "app-store",
      skip_profile_detection: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: { APP_ID => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      # Don't idle on a macOS runner (billed at 10x) waiting for Apple to finish
      # processing. The upload succeeding is the signal that matters; processing
      # failures arrive by email and show in App Store Connect either way.
      skip_waiting_for_build_processing: true
    )
  end
end
