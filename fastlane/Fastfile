default_platform(:ios)

APP_ID  = "com.appstudio.passcheck"
TEAM_ID = "645SRC2PTY"

platform :ios do
  desc "Build PassCheck and upload to TestFlight (App Store Connect API key, manual signing)"
  lane :beta do
    # CI machines have no login keychain / Apple account. This creates a temporary
    # keychain so the signing certificate can be imported.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"] || "asc_key.p8"
    )

    # NOTE: `produce` cannot create the App Store Connect app record with an API key
    # (Apple requires an Apple ID login for that). The record is created once by hand
    # in App Store Connect; see TESTFLIGHT_SETUP.md.

    # Certificates must land in the temporary CI keychain, not the (locked) login keychain.
    keychain_name = ENV["MATCH_KEYCHAIN_NAME"] || "fastlane_tmp_keychain"
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    keychain_pw   = ENV["MATCH_KEYCHAIN_PASSWORD"] || ""

    cert_opts = {
      api_key: api_key,
      team_id: TEAM_ID,
      keychain_path: keychain_path,
      keychain_password: keychain_pw
    }

    begin
      cert(cert_opts)
    rescue => e
      # CI machines are destroyed after every run, so the private key of a
      # CI-created certificate is lost and the certificate becomes unusable.
      # Once Apple's distribution-certificate limit is hit, clear the dead ones
      # and retry. Owner approved this cleanup (2026-07-20).
      raise e unless e.message.to_s.include?("maximum number")

      UI.important("Distribution certificate limit reached — revoking unusable certificates.")
      revoked = 0
      Spaceship::ConnectAPI::Certificate.all.each do |c|
        next unless c.certificate_type.to_s.upcase.include?("DISTRIBUTION")
        UI.important("Revoking #{c.id} (#{c.display_name}, #{c.certificate_type})")
        c.delete!
        revoked += 1
      end
      UI.user_error!("Limit reached but no distribution certificates found to revoke.") if revoked.zero?
      UI.success("Revoked #{revoked} unusable certificate(s) — creating a fresh one.")
      cert(cert_opts)
    end
    # sigh needs the bundle identifier to already exist on the developer portal.
    if Spaceship::ConnectAPI::BundleId.find(APP_ID).nil?
      UI.important("Registering bundle identifier #{APP_ID}")
      Spaceship::ConnectAPI::BundleId.create(name: "PassCheck", identifier: APP_ID)
    end

    sigh(api_key: api_key, app_identifier: APP_ID, team_id: TEAM_ID)

    profile_name = lane_context[SharedValues::SIGH_NAME]
    UI.message("Using provisioning profile: #{profile_name}")

    # Automatic signing cannot work without a logged-in Xcode account — switch to manual.
    update_code_signing_settings(
      path: "PassCheck.xcodeproj",
      use_automatic_signing: false,
      team_id: TEAM_ID,
      targets: ["PassCheck"],
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name
    )

    build_app(
      project: "PassCheck.xcodeproj",
      scheme: "PassCheck",
      export_method: "app-store",
      skip_profile_detection: true,
      export_options: {
        signingStyle: "manual",
        teamID: TEAM_ID,
        provisioningProfiles: { APP_ID => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
